        "from sklearn.model_selection import train_test_split, GroupShuffleSplit\n",
        "\n",
        "feature_cols = [\n",
        "    \"impressions_90d\",\n",
        "    \"avg_position_last30\",\n",
        "    \"avg_position_prev30\",\n",
        "    \"rare_query_count\",\n",
        "    \"rare_impressions_share\",\n",
        "    \"anonymized_impressions_share\",\n",
        "    \"query_concentration\"\n",
        "]\n",
        "\n",
        "X = data_90d[feature_cols]\n",
        "y = data_90d[\"avg_position_90d\"]\n",
        "groups = data_90d[\"client_hash_id\"]"
      ],
