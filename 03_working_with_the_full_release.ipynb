        "# Build content-level features using a 90-day window\n",
        "# Keep content with at least 10 observations\n",
        "\n",
        "data_90d = con.sql(f\"\"\"\n",
        "    SELECT\n",
        "        client_hash_id,\n",
        "        content_hash_id,\n",
        "        SUM(impressions_90d) AS impressions_90d,\n",
        "        AVG(avg_position_90d) AS avg_position_90d,\n",
        "        AVG(avg_position_last30) AS avg_position_last30,\n",
        "        AVG(avg_position_prev30) AS avg_position_prev30,\n",
        "        SUM(rare_query_count) AS rare_query_count,\n",
        "        SUM(rare_impressions_share) AS rare_impressions_share,\n",
        "        SUM(anonymized_impressions_share) AS anonymized_impressions_share,\n",
        "        COUNT(*) AS query_count\n",
        "    FROM {TABLES['fact_query_90d']}\n",
        "    GROUP BY\n",
        "        client_hash_id,\n",
        "        content_hash_id\n",
        "    HAVING COUNT(*) >= 10\n",
        "\"\"\").df()\n",
        "\n",
        "data_90d.head()"
      ],
